# IMSERV Platform Environment Configuration
# Copy to .env for local development. On Render, set these in the dashboard.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string

# Database (optional - leave blank to use file-based CSV storage)
DATABASE_URL=

# Existing AI recommendations feature (optional)
OPENAI_API_KEY=

# Floating chatbot via Hugging Face Inference Providers
# On Render, add HF_TOKEN as a secret environment variable.
HF_TOKEN=
HF_CHAT_PROVIDER=novita
HF_CHAT_MODEL=google/gemma-4-31B-it
HF_CHAT_BASE_URL=https://router.huggingface.co/v1
# HF_CHAT_ENDPOINT=https://your-endpoint.endpoints.huggingface.cloud/v1/chat/completions

# Optional chatbot tuning
HF_CHAT_TIMEOUT_SECONDS=45
HF_CHAT_MAX_TOKENS=450
HF_CHAT_TEMPERATURE=0.35

# Feature Flags
ENABLE_AI_RECOMMENDATIONS=false
ENABLE_DATABASE=false
ENABLE_EXPORT=true

# Data Paths
DATA_DIR=./data

# Render.com / Production
PORT=5000
